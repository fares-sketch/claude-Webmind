{
  "name": "WebMind — Prospection Engine",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "prospection-engine",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "node-webhook",
      "name": "Prospection Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [200, 400],
      "webhookId": "prospect-engine-001"
    },
    {
      "parameters": {
        "jsCode": "// Extract prospects array and campaign metadata\nconst body = $input.first().json.body ?? $input.first().json;\nconst prospects = body.prospects;\nconst campaign = body.campaign || 'Unknown';\nconst icp_criteria = body.icp_criteria || '';\n\nif (!prospects || !Array.isArray(prospects) || prospects.length === 0) {\n  throw new Error('Missing or empty prospects array');\n}\n\n// Return each prospect as a separate item for batch processing\nreturn prospects.map(p => ({\n  json: {\n    first_name: p.first_name || '',\n    last_name: p.last_name || '',\n    title: p.title || '',\n    company: p.company || '',\n    company_size: p.company_size || '',\n    industry: p.industry || '',\n    email: p.email || '',\n    phone: p.phone || '',\n    linkedin_url: p.linkedin_url || '',\n    location: p.location || '',\n    campaign: p.campaign || campaign,\n    icp_criteria: icp_criteria,\n    received_at: new Date().toISOString()\n  }\n}));"
      },
      "id": "node-parse",
      "name": "Parse Prospects",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 400]
    },
    {
      "parameters": {
        "jsCode": "// Score each prospect using Claude Haiku API\n// This node processes items one by one, preserving prospect data\nconst prospect = $input.first().json;\n\nconst prompt = `Tu es un expert en qualification de prospects B2B pour WebMind, une agence d'automatisation IA.\n\nNotre ICP (Ideal Customer Profile) :\n- Poste : CEO, DG, Directeur Commercial, Directeur Operations, COO\n- Entreprise : PME B2B francaise, 5 a 100 employes\n- Secteur : tous secteurs B2B (services, tech, industrie, conseil, immobilier, sante B2B)\n- Probleme cible : processus manuels repetitifs, leads non suivis, appels manques\n\nProspect a evaluer :\nPrenom : ${prospect.first_name}\nNom : ${prospect.last_name}\nTitre : ${prospect.title}\nEntreprise : ${prospect.company}\nTaille : ${prospect.company_size} employes\nSecteur : ${prospect.industry}\nLocalisation : ${prospect.location}\n\nRetourne uniquement ce JSON :\n{\"score\": \"Hot\" | \"Warm\" | \"Cold\", \"raison\": \"string (max 2 phrases, en francais)\"}\n\nCriteres :\n- Hot = decideur confirme (CEO/DG/Dir), PME B2B France, taille dans la cible\n- Warm = decideur probable mais info incomplete, ou taille legerement hors cible\n- Cold = pas decideur, hors France, hors ICP, trop grande/petite entreprise`;\n\ntry {\n  const response = await $helpers.httpRequest({\n    method: 'POST',\n    url: 'https://api.anthropic.com/v1/messages',\n    headers: {\n      'x-api-key': $env.ANTHROPIC_API_KEY,\n      'anthropic-version': '2023-06-01',\n      'content-type': 'application/json'\n    },\n    body: JSON.stringify({\n      model: 'claude-haiku-4-5-20251001',\n      max_tokens: 300,\n      messages: [{ role: 'user', content: prompt }]\n    })\n  });\n\n  const content = response.content[0].text;\n  let parsed;\n  try {\n    let cleanContent = content.trim();\n    if (cleanContent.startsWith('```')) {\n      cleanContent = cleanContent.replace(/^```(?:json)?\\n?/, '').replace(/\\n?```$/, '');\n    }\n    parsed = JSON.parse(cleanContent);\n  } catch(e) {\n    parsed = { score: 'Warm', raison: 'Erreur parsing IA - review manuel necessaire' };\n  }\n\n  return [{ json: {\n    ...prospect,\n    score: parsed.score || 'Warm',\n    raison: parsed.raison || 'Non qualifie automatiquement'\n  } }];\n\n} catch(e) {\n  // Fallback if Claude API fails\n  return [{ json: {\n    ...prospect,\n    score: 'Warm',\n    raison: 'API indisponible - qualification manuelle requise'\n  } }];\n}"
      },
      "id": "node-ai-score",
      "name": "Claude Haiku Scoring",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 400]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": { "caseSensitive": false },
                "conditions": [
                  {
                    "leftValue": "={{ $json.score }}",
                    "rightValue": "Cold",
                    "operator": { "type": "string", "operation": "notEquals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "Hot_or_Warm"
            },
            {
              "conditions": {
                "options": { "caseSensitive": false },
                "conditions": [
                  {
                    "leftValue": "={{ $json.score }}",
                    "rightValue": "Cold",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "Cold"
            }
          ]
        },
        "options": {}
      },
      "id": "node-router",
      "name": "Route by Score",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [920, 400]
