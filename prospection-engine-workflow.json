    {
      "parameters": {
        "jsCode": "// Aggregate results by referencing the Claude Scoring node output directly\n// This avoids data loss from Airtable/Slack response overwriting prospect data\nconst allScored = $('Claude Haiku Scoring').all();\n\nlet hot = 0, warm = 0, cold = 0;\nfor (const item of allScored) {\n  const score = (item.json.score || '').toLowerCase();\n  if (score === 'hot') hot++;\n  else if (score === 'warm') warm++;\n  else cold++;\n}\n\nreturn [{ json: {\n  success: true,\n  processed: allScored.length,\n  hot: hot,\n  warm: warm,\n  cold: cold,\n  message: `${allScored.length} prospects traites: ${hot} Hot, ${warm} Warm, ${cold} Cold`\n} }];"
      },
      "id": "node-aggregate",
      "name": "Aggregate Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1640, 400]
    },
